# Copy to .env and adjust values. Used by Docker Compose and the app (pydantic-settings).

POSTGRES_USER=nishack
POSTGRES_PASSWORD=nishack_secret
POSTGRES_DB=nishack

# For docker-compose `web` service use host `db`. For local runs without Docker use `localhost`.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# HS256 signing secret for JWT (use a long random string in production).
JWT_SECRET=replace-with-a-long-random-secret-in-production
